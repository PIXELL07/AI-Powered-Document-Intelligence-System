ENV=development
SECRET_KEY=change-me

# Railway injects these automatically when you attach Postgres/Redis
# plugins. Set manually for local dev.
DATABASE_URL=sqlite:///./docintel.db
REDIS_URL=redis://localhost:6379/0

UPLOAD_DIR=/tmp/docintel_uploads

OCR_CONFIDENCE_THRESHOLD=60.0
OCR_LANGUAGES=eng

MIN_TERMINATION_NOTICE_DAYS=15
MAX_PAYMENT_TERMS_DAYS=90
YOY_CHANGE_THRESHOLD_PCT=35.0

CRM_PROVIDER=notion
NOTION_API_KEY=
NOTION_DATABASE_ID=
AIRTABLE_API_KEY=
AIRTABLE_BASE_ID=
AIRTABLE_TABLE_NAME=Documents

MODEL_IDLE_UNLOAD_SECONDS=120
MAX_CONCURRENT_MODELS=1

FRONTEND_ORIGIN=http://localhost:5173
CELERY_CONCURRENCY=2
